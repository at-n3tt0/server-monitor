APP_NAME=server-monitor
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8010
CORS_ORIGINS=["http://localhost:5173"]

POSTGRES_DB=server_monitor
POSTGRES_USER=server_monitor
POSTGRES_PASSWORD=server_monitor
POSTGRES_PORT=55432
DATABASE_URL=postgresql+psycopg2://server_monitor:server_monitor@localhost:55432/server_monitor

JWT_SECRET=change-me-now
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123!

MONITORING_POLL_INTERVAL_SECONDS=10
DASHBOARD_DEFAULT_RANGE_MINUTES=60
AUTO_IMPORT_LEGACY_TARGETS=false
AUTO_IMPORT_LEGACY_HISTORY=false

# Restricao opcional para agentes proprios
SERVER_MONITOR_ALLOWED_MONITOR_IP=

# Proxmox PVE
SERVER_MONITOR_PVE_API_TOKEN_ID=
SERVER_MONITOR_PVE_API_TOKEN_SECRET=
SERVER_MONITOR_PVE_SSH_PASSWORD=

# Windows hosts
SERVER_MONITOR_SRV00_PASSWORD=
SERVER_MONITOR_SRV01_PASSWORD=
SERVER_MONITOR_SRV01_AGENT_TOKEN=
SERVER_MONITOR_SRV03_PASSWORD=
SERVER_MONITOR_SRV04_PASSWORD=

# Linux host cicel
SERVER_MONITOR_CICEL_SSH_PASSWORD=
SERVER_MONITOR_CICEL_SSH_KEY_PATH=

# MikroTik CCR
SERVER_MONITOR_MIKROTIK_PASSWORD=
