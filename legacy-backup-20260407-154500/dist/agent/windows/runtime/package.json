{
  "name": "infrawatch-agent-runtime",
  "version": "1.0.0",
  "private": true,
  "description": "Runtime minimo do InfraWatch Agent para instalacao dedicada",
  "main": "src/service.js",
  "scripts": {
    "start": "node src/service.js --config ./config/agent.config.json"
  },
  "pkg": {
    "assets": [
      "node_modules/systeminformation/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "../dist/agent/windows"
  },
  "dependencies": {
    "systeminformation": "^5.31.5"
  }
}
